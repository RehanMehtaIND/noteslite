{
  "name": "noteslite",
  "version": "2.0.0",
  "private": true,
  "description": "NOTESLITE migrated to Next.js + Prisma + PostgreSQL",
  "scripts": {
    "dev": "next dev frontend",
    "build": "next build frontend",
    "vercel-build": "prisma migrate deploy --schema=backend/prisma/schema.prisma && prisma generate --schema=backend/prisma/schema.prisma && next build frontend",
    "start": "next start frontend",
    "lint": "next lint frontend",
    "postinstall": "prisma generate --schema=backend/prisma/schema.prisma",
    "prisma:generate": "prisma generate --schema=backend/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=backend/prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema=backend/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=backend/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "autoprefixer": "^10.4.27",
    "next": "^15.1.0",
    "next-auth": "^4.24.13",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ua-parser-js": "^2.0.9",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/ua-parser-js": "^0.7.39",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "prisma": "^6.4.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2"
  }
}
