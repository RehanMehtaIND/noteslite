generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id                String      @id @default(uuid()) @db.Uuid
  googleId          String?     @unique @map("google_id")
  passwordHash      String?     @map("password_hash")
  email             String      @unique
  name              String
  createdAt         DateTime    @default(now()) @map("created_at")
  
  emailVerified     Boolean     @default(false) @map("email_verified")
  emailVerifyOtp    String?     @map("email_verify_otp")
  emailVerifyExpiry DateTime?   @map("email_verify_expiry")
  
  twoFactorEnabled  Boolean     @default(false) @map("two_factor_enabled")
  twoFactorMethod   String?     @default("authenticator") @map("two_factor_method")

  avatarMode        String?     @default("initials") @map("avatar_mode")
  avatarUrl         String?     @map("avatar_url")
  displayName       String?     @map("display_name")
  showEmail         Boolean     @default(false) @map("show_email")

  sessions          Session[]
  quickNotes        QuickNote[]
  workspaces        Workspace[]

  @@map("users")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceName   String   
  browser      String   
  os           String   
  ipAddress    String?  @map("ip_address")
  lastActiveAt DateTime @default(now()) @map("last_active_at")
  createdAt    DateTime @default(now()) @map("created_at")
  sessionToken String   @unique @map("session_token")
  isActive     Boolean  @default(true) @map("is_active")
  
  @@index([userId])
  @@map("sessions")
}

// ─── Workspaces ──────────────────────────────────────────────────────────────

model Workspace {
  id          String       @id @default(uuid()) @db.Uuid
  name        String
  theme       String       @default("default")
  userId      String       @map("user_id") @db.Uuid
  createdAt   DateTime     @default(now()) @map("created_at")
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  columns     Column[]
  cards       Card[]
  tags        Tag[]
  connections Connection[]

  @@index([userId])
  @@map("workspaces")
}

// ─── Columns ─────────────────────────────────────────────────────────────────

model Column {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  orderIndex  Int       @map("order_index")
  workspaceId String    @map("workspace_id") @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  cards       Card[]

  @@index([workspaceId])
  @@map("columns")
}

// ─── Cards ───────────────────────────────────────────────────────────────────

model Card {
  id                String       @id @default(uuid()) @db.Uuid
  title             String
  content           Json?
  coverImage        String?      @map("cover_image")
  positionX         Float        @default(0) @map("position_x")
  positionY         Float        @default(0) @map("position_y")
  columnId          String?      @map("column_id") @db.Uuid
  workspaceId       String       @map("workspace_id") @db.Uuid
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  column            Column?      @relation(fields: [columnId], references: [id], onDelete: SetNull)
  workspace         Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tags              Tag[]        @relation("CardTags")
  sourceConnections Connection[] @relation("SourceCard")
  targetConnections Connection[] @relation("TargetCard")

  @@index([workspaceId])
  @@index([columnId])
  @@map("cards")
}

// ─── Tags ────────────────────────────────────────────────────────────────────

model Tag {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  color       String
  workspaceId String    @map("workspace_id") @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  cards       Card[]    @relation("CardTags")

  @@index([workspaceId])
  @@map("tags")
}

// ─── Connections ─────────────────────────────────────────────────────────────

model Connection {
  id           String    @id @default(uuid()) @db.Uuid
  sourceCardId String    @map("source_card_id") @db.Uuid
  targetCardId String    @map("target_card_id") @db.Uuid
  workspaceId  String    @map("workspace_id") @db.Uuid
  sourceCard   Card      @relation("SourceCard", fields: [sourceCardId], references: [id], onDelete: Cascade)
  targetCard   Card      @relation("TargetCard", fields: [targetCardId], references: [id], onDelete: Cascade)
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([sourceCardId])
  @@index([targetCardId])
  @@map("connections")
}

// ─── Quick Notes ─────────────────────────────────────────────────────────────

model QuickNote {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String
  color       String
  pinned      Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("quick_notes")
}
